# ──────────────────────────────────────────────────────────────
# .env.production — OpenReview Studio
#
# Copy this file to .env.production and fill in all values.
# Used by: docker compose -f docker-compose.production.yml --env-file .env.production up -d
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=openreview
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=openreview
POSTGRES_PORT=5433

# ── Redis ──────────────────────────────────────────────────────
REDIS_PORT=6380

# ── MinIO (S3-compatible storage) ──────────────────────────────
MINIO_ROOT_USER=openreview
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_secret_at_least_8_chars
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# S3 bucket names
S3_BUCKET_ORIGINALS=originals
S3_BUCKET_PROXIES=proxies
S3_REGION=us-east-1

# Public endpoint for presigned URLs. This is the URL browsers and the
# Adobe CEP panel use to upload/download files directly from MinIO.
# Must match the domain nginx is serving and proxying to MinIO.
S3_PUBLIC_ENDPOINT=https://studio.arunsamuel.com

# ── Authentication ─────────────────────────────────────────────
# MUST be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# ── Public URLs ────────────────────────────────────────────────
# The URL where the web app is reachable by browsers.
WEB_URL=https://studio.arunsamuel.com

# The URL where the API is reachable by browsers (baked into Next.js at
# build time). With nginx path-based routing (/api/* → API server):
NEXT_PUBLIC_API_URL=https://studio.arunsamuel.com/api

# CORS: additional origins allowed to call the API (comma-separated).
# The web app origin (WEB_URL) is always allowed.
CORS_ORIGINS=https://studio.arunsamuel.com

# ── Exposed ports ──────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3001

# ── Worker ─────────────────────────────────────────────────────
# Number of concurrent ffmpeg transcode jobs
WORKER_CONCURRENCY=2

# ── Email (optional) ──────────────────────────────────────────
# Leave SMTP_HOST empty to disable outgoing email.
MAIL_FROM=OpenReview Studio <noreply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
